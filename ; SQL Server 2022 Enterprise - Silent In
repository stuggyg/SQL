; SQL Server 2022 Enterprise - Silent Install
[OPTIONS]

ACTION="Install"
FEATURES=SQLENGINE
INSTANCENAME="MSSQLSERVER"
INSTANCEID="MSSQLSERVER"

; Authentication
SECURITYMODE="SQL"
SAPWD="ChangeMeStrongPassword!"
SQLSYSADMINACCOUNTS="DOMAIN\DBAGroup"

; Service Accounts
SQLSVCACCOUNT="DOMAIN\SQL_Engine"
SQLSVCPASSWORD="ChangeMe!"
AGTSVCACCOUNT="DOMAIN\SQL_Agent"
AGTSVCPASSWORD="ChangeMe!"

; Services
SQLSVCSTARTUPTYPE="Automatic"
AGTSVCSTARTUPTYPE="Automatic"
BROWSERSVCSTARTUPTYPE="Automatic"

; Network Protocols
TCPENABLED="1"
NPENABLED="1"

; Directories
INSTALLSQLDATADIR="E:\MSSQL"
SQLUSERDBDIR="E:\MSSQL\Data"
SQLUSERDBLOGDIR="L:\MSSQL\Log"
SQLTEMPDBDIR="T:\MSSQL\TempDB"
SQLTEMPDBLOGDIR="T:\MSSQL\TempDB"
SQLBACKUPDIR="E:\MSSQL\Backup"

; TempDB
SQLTEMPDBFILECOUNT="4"
SQLTEMPDBFILESIZE="4096"
SQLTEMPDBFILEGROWTH="512"
SQLTEMPDBLOGFILESIZE="2048"
SQLTEMPDBLOGFILEGROWTH="256"

; Accept License
IACCEPTSQLSERVERLICENSETERMS="True"

; Quiet Mode
QUIET="True"
QUIETSIMPLE="True"
